library(dRiftDM)
library(ggplot2)
source("dRiftDMHelper.R")
mu_mddm <- function(prms_model, prms_solve, t_vec, one_cond, ddm_opts) {
muc = prms_model[["muc"]]
mua1 = prms_model[["mua1"]]
mua2 = prms_model[["mua2"]]
mu_c <- muc * t_vec
mu_a1 <- (mua1 * auto1) * t_vec
mu_a2 <- (mua2 * auto2) * t_vec
return (max(muc, mua1, mua2))
}
